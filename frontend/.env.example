# Frontend Environment Variables
# ─────────────────────────────────────────────────────────────

# In LOCAL DEV: leave this empty (Vite proxy handles /api → localhost:5000)
# VITE_API_URL=

# In PRODUCTION (Vercel): set this to your deployed backend URL
# Example: https://infohub-api.vercel.app/api
VITE_API_URL=https://your-backend-url.vercel.app/api
