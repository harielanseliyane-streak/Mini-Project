# Frontend Environment Variables
# ─────────────────────────────────────────────────────────────

# In LOCAL DEV: leave this empty (Vite proxy handles /api → localhost:5000)
# VITE_API_URL=

# In PRODUCTION (Vercel): set this to your deployed backend URL
# If using monorepo deployment (same Vercel project), use /api
# If backend is a separate Vercel project, use its full URL
VITE_API_URL=https://your-infohub-backend.vercel.app/api

# ─── Supabase (optional – only if you use Supabase client-side) ──
# Not required for this project since all Supabase calls are server-side
# VITE_SUPABASE_URL=https://your-project-id.supabase.co
# VITE_SUPABASE_ANON_KEY=your-anon-key
