# ── Dependencies ──────────────────────────
node_modules/
**/node_modules/

# ── Build outputs ─────────────────────────
frontend/dist/
frontend/.vite/

# ── Environment files (NEVER commit real secrets) ──
.env
**/.env
# Commit .env.example files (they contain no secrets)
!.env.example
!**/.env.example

# ── Uploaded files (use Cloudinary in prod) ──
backend/uploads/

# ── Logs ─────────────────────────────────
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# ── OS files ─────────────────────────────
.DS_Store
Thumbs.db

# ── IDE ───────────────────────────────────
.vscode/
.idea/
*.suo
*.user

# ── Prisma ────────────────────────────────
# Keep schema.prisma but ignore generated client
backend/node_modules/.prisma/
