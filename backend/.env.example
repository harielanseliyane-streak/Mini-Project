# ─── Server ────────────────────────────────────────────────────
PORT=5000
NODE_ENV=production

# ─── Supabase ──────────────────────────────────────────────────
# Get from: https://supabase.com → Your Project → Settings → API
SUPABASE_URL=https://your-project-id.supabase.co
SUPABASE_ANON_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9.your-anon-key-here
SUPABASE_SERVICE_ROLE_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9.your-service-role-key-here

# ─── Supabase PostgreSQL for Prisma ────────────────────────────
# Get from: Supabase → Settings → Database → Connection string → URI
# Use Session mode (port 5432) for Prisma compatibility
DATABASE_URL=postgresql://postgres.your-project-id:your-db-password@aws-0-ap-south-1.pooler.supabase.com:5432/postgres

# ─── JWT ───────────────────────────────────────────────────────
JWT_SECRET=change_this_to_a_long_random_string_in_production
JWT_EXPIRES_IN=7d

# ─── AI Chatbot ────────────────────────────────────────────────
OPENAI_API_KEY=your_openai_api_key_here
GEMINI_API_KEY=your_gemini_api_key_here

# ─── File Upload limits ─────────────────────────────────────────
MAX_FILE_SIZE=10485760

# ─── Frontend URL (for CORS) ───────────────────────────────────
# Set to your Vercel frontend deployment URL
CLIENT_URL=https://your-frontend.vercel.app
