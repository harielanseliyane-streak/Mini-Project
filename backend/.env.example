# ─── Server ───────────────────────────────
PORT=5000
NODE_ENV=production

# ─── MySQL / PlanetScale ──────────────────
# Copy the connection string from your cloud DB dashboard (PlanetScale / Railway)
DATABASE_URL=mysql://user:password@host:3306/infohub

# ─── JWT ──────────────────────────────────
JWT_SECRET=change_this_to_a_long_random_string_in_production
JWT_EXPIRES_IN=7d

# ─── AI Chatbot ───────────────────────────
OPENAI_API_KEY=your_openai_api_key_here
GEMINI_API_KEY=your_gemini_api_key_here

# ─── Cloudinary (file uploads) ────────────
# Sign up free at https://cloudinary.com – copy values from the Dashboard
CLOUDINARY_CLOUD_NAME=your_cloud_name
CLOUDINARY_API_KEY=your_cloudinary_api_key
CLOUDINARY_API_SECRET=your_cloudinary_api_secret

# ─── File Upload limits ───────────────────
MAX_FILE_SIZE=10485760

# ─── Frontend URL (for CORS) ──────────────
# Set to your Vercel frontend deployment URL
CLIENT_URL=https://your-frontend.vercel.app
