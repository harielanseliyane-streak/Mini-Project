datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
}

generator client {
  provider = "prisma-client-js"
}

// ─────────────────────────────────────────
// 1. USER AUTH & BASE MODEL
// ─────────────────────────────────────────
model User {
  id           Int           @id @default(autoincrement())
  role         String        // 'student' | 'college' | 'admin'
  name         String
  email        String        @unique
  passwordHash String        @map("password_hash")
  phone        String?
  createdAt    DateTime      @default(now()) @map("created_at")
  updatedAt    DateTime      @updatedAt @map("updated_at")

  student       Student?
  college       College?
  notifications Notification[]
  activityLogs  ActivityLog[]

  @@map("users")
}

// ─────────────────────────────────────────
// 2. STUDENT PROFILE
// ─────────────────────────────────────────
model Student {
  userId            Int               @id @map("user_id")
  user              User              @relation(fields: [userId], references: [id], onDelete: Cascade)
  hscMarks          Float?            @map("hsc_marks")
  cutoff            Float?
  profilePhoto      String?           @map("profile_photo")
  bio               String?
  interests         String?
  skills            String?
  careerGoals       String?           @map("career_goals")
  locationPref      String?           @map("location_pref")
  budgetPref        Float?            @map("budget_pref")
  coursePref        String?           @map("course_pref")

  applications       Application[]
  eventRegistrations EventRegistration[]
  reviews            Review[]
  ratings            Rating[]
  quizResults        QuizResult[]
  aiRecommendations  AIRecommendation[]
  savedItems         SavedItem[]

  @@map("students")
}

// ─────────────────────────────────────────
// 3. COLLEGE PROFILE
// ─────────────────────────────────────────
model College {
  userId         Int             @id @map("user_id")
  user           User            @relation(fields: [userId], references: [id], onDelete: Cascade)
  collegeName    String          @map("college_name")
  address        String?
  city           String?
  state          String?
  website        String?
  logo           String?
  description    String?
  established    Int?
  accreditation  String?
  infrastructure String?
  hostelInfo     String?         @map("hostel_info")
  feeStructure   String?         @map("fee_structure")

  courses      Course[]
  events       Event[]
  scholarships Scholarship[]
  placements   PlacementData[]
  applications Application[]
  reviews      Review[]
  ratings      Rating[]
  posts        Post[]

  @@map("colleges")
}

// ─────────────────────────────────────────
// 4. COURSES
// ─────────────────────────────────────────
model Course {
  id           Int           @id @default(autoincrement())
  collegeId    Int           @map("college_id")
  college      College       @relation(fields: [collegeId], references: [userId], onDelete: Cascade)
  courseName   String        @map("course_name")
  cutoff       Float
  seats        Int?
  duration     String?
  department   String?
  feePerYear   Float?        @map("fee_per_year")
  createdAt    DateTime      @default(now()) @map("created_at")

  applications Application[]

  @@map("courses")
}

// ─────────────────────────────────────────
// 5. POSTS (college feed / announcements)
// ─────────────────────────────────────────
model Post {
  id          Int      @id @default(autoincrement())
  collegeId   Int      @map("college_id")
  college     College  @relation(fields: [collegeId], references: [userId], onDelete: Cascade)
  type        String   @default("general")
  title       String
  description String?
  mediaUrl    String?  @map("media_url")
  mediaType   String?  @default("none") @map("media_type")
  createdAt   DateTime @default(now()) @map("created_at")

  @@map("posts")
}

// ─────────────────────────────────────────
// 6. EVENTS / SYMPOSIUMS
// ─────────────────────────────────────────
model Event {
  id                   Int                 @id @default(autoincrement())
  collegeId            Int                 @map("college_id")
  college              College             @relation(fields: [collegeId], references: [userId], onDelete: Cascade)
  name                 String
  description          String?
  eventDate            DateTime            @map("event_date")
  location             String?
  posterUrl            String?             @map("poster_url")
  registrationDeadline DateTime?           @map("registration_deadline")
  maxParticipants      Int?                @map("max_participants")
  createdAt            DateTime            @default(now()) @map("created_at")

  registrations EventRegistration[]
  applications  Application[]

  @@map("events")
}

// ─────────────────────────────────────────
// 7. EVENT REGISTRATION TRACKER
// ─────────────────────────────────────────
model EventRegistration {
  id           Int      @id @default(autoincrement())
  eventId      Int      @map("event_id")
  event        Event    @relation(fields: [eventId], references: [id], onDelete: Cascade)
  studentId    Int      @map("student_id")
  student      Student  @relation(fields: [studentId], references: [userId], onDelete: Cascade)
  registeredAt DateTime @default(now()) @map("registered_at")

  @@unique([eventId, studentId])
  @@map("event_registrations")
}

// ─────────────────────────────────────────
// 8. SCHOLARSHIPS
// ─────────────────────────────────────────
model Scholarship {
  id          Int       @id @default(autoincrement())
  collegeId   Int?      @map("college_id")
  college     College?  @relation(fields: [collegeId], references: [userId], onDelete: Cascade)
  type        String    @default("private")
  name        String
  description String?
  amount      Float?
  eligibility String?
  deadline    DateTime?
  createdAt   DateTime  @default(now()) @map("created_at")

  @@map("scholarships")
}

// ─────────────────────────────────────────
// 9. INTERNSHIPS
// ─────────────────────────────────────────
model Internship {
  id             Int           @id @default(autoincrement())
  companyName    String        @map("company_name")
  title          String
  description    String?
  stipend        Float?
  duration       String?
  location       String?
  eligibility    String?
  skillsRequired String?       @map("skills_required")
  deadline       DateTime?
  createdAt      DateTime      @default(now()) @map("created_at")

  applications Application[]

  @@map("internships")
}

// ─────────────────────────────────────────
// 10. ADMISSIONS & INTERNSHIP APPLICATIONS
// ─────────────────────────────────────────
model Application {
  id           Int         @id @default(autoincrement())
  studentId    Int         @map("student_id")
  student      Student     @relation(fields: [studentId], references: [userId], onDelete: Cascade)
  collegeId    Int         @map("college_id")
  college      College     @relation(fields: [collegeId], references: [userId], onDelete: Cascade)
  courseId     Int?        @map("course_id")
  course       Course?     @relation(fields: [courseId], references: [id], onDelete: SetNull)
  type         String      @default("admission")
  eventId      Int?        @map("event_id")
  event        Event?      @relation(fields: [eventId], references: [id], onDelete: SetNull)
  internshipId Int?        @map("internship_id")
  internship   Internship? @relation(fields: [internshipId], references: [id], onDelete: SetNull)
  status       String      @default("pending")
  message      String?
  appliedAt    DateTime    @default(now()) @map("applied_at")
  updatedAt    DateTime    @updatedAt @map("updated_at")

  @@map("applications")
}

// ─────────────────────────────────────────
// 11. REVIEWS
// ─────────────────────────────────────────
model Review {
  id        Int      @id @default(autoincrement())
  studentId Int      @map("student_id")
  student   Student  @relation(fields: [studentId], references: [userId], onDelete: Cascade)
  collegeId Int      @map("college_id")
  college   College  @relation(fields: [collegeId], references: [userId], onDelete: Cascade)
  content   String
  rating    Int      @default(5)
  createdAt DateTime @default(now()) @map("created_at")

  @@map("reviews")
}

// ─────────────────────────────────────────
// 12. RATINGS
// ─────────────────────────────────────────
model Rating {
  id        Int     @id @default(autoincrement())
  studentId Int     @map("student_id")
  student   Student @relation(fields: [studentId], references: [userId], onDelete: Cascade)
  collegeId Int     @map("college_id")
  college   College @relation(fields: [collegeId], references: [userId], onDelete: Cascade)
  score     Int

  @@map("ratings")
}

// ─────────────────────────────────────────
// 13. NOTIFICATIONS
// ─────────────────────────────────────────
model Notification {
  id        Int      @id @default(autoincrement())
  userId    Int      @map("user_id")
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  title     String
  message   String
  isRead    Boolean  @default(false) @map("is_read")
  createdAt DateTime @default(now()) @map("created_at")

  @@map("notifications")
}

// ─────────────────────────────────────────
// 14. QUIZ RESULTS
// ─────────────────────────────────────────
model QuizResult {
  id              Int      @id @default(autoincrement())
  studentId       Int      @map("student_id")
  student         Student  @relation(fields: [studentId], references: [userId], onDelete: Cascade)
  careerPath      String   @map("career_path")
  personality     String
  aptitudeScore   Float    @map("aptitude_score")
  interestMapping String?  @map("interest_mapping")
  skillsAnalysis  String?  @map("skills_analysis")
  recommendations String?
  createdAt       DateTime @default(now()) @map("created_at")

  @@map("quiz_results")
}

// ─────────────────────────────────────────
// 15. PLACEMENT RECORD
// ─────────────────────────────────────────
model PlacementData {
  id               Int      @id @default(autoincrement())
  collegeId        Int      @map("college_id")
  college          College  @relation(fields: [collegeId], references: [userId], onDelete: Cascade)
  year             Int
  highestPackage   Float?   @map("highest_package")
  averagePackage   Float?   @map("average_package")
  placementPercent Float?   @map("placement_percent")
  topRecruiters    String?  @map("top_recruiters")
  description      String?
  createdAt        DateTime @default(now()) @map("created_at")

  @@map("placements")
}

// ─────────────────────────────────────────
// 16. AI RECOMMENDATIONS
// ─────────────────────────────────────────
model AIRecommendation {
  id           Int      @id @default(autoincrement())
  studentId    Int      @map("student_id")
  student      Student  @relation(fields: [studentId], references: [userId], onDelete: Cascade)
  colleges     String?
  scholarships String?
  careers      String?
  generatedAt  DateTime @default(now()) @map("generated_at")

  @@map("ai_recommendations")
}

// ─────────────────────────────────────────
// 17. SAVED ITEMS
// ─────────────────────────────────────────
model SavedItem {
  id        Int      @id @default(autoincrement())
  studentId Int      @map("student_id")
  student   Student  @relation(fields: [studentId], references: [userId], onDelete: Cascade)
  type      String
  itemId    Int      @map("item_id")
  createdAt DateTime @default(now()) @map("created_at")

  @@unique([studentId, type, itemId])
  @@map("saved_items")
}

// ─────────────────────────────────────────
// 18. ACTIVITY LOGS
// ─────────────────────────────────────────
model ActivityLog {
  id        Int      @id @default(autoincrement())
  userId    Int      @map("user_id")
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  action    String
  details   String?
  timestamp DateTime @default(now())

  @@map("activity_logs")
}
