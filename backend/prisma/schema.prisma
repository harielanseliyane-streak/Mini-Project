datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

generator client {
  provider = "prisma-client-js"
}

// ─────────────────────────────────────────
// 1. USER AUTH & BASE MODEL
// ─────────────────────────────────────────
model User {
  id           Int           @id @default(autoincrement())
  role         String        // 'student' | 'college' | 'admin'
  name         String
  email        String        @unique
  passwordHash String        @map("password_hash")
  phone        String?
  createdAt    DateTime      @default(now()) @map("created_at")
  updatedAt    DateTime      @updatedAt @map("updated_at")

  student      Student?
  college      College?
  notifications Notification[]
  activityLogs ActivityLog[]

  @@map("users")
}

// ─────────────────────────────────────────
// 2. STUDENT PROFILE
// ─────────────────────────────────────────
model Student {
  userId            Int               @id @map("user_id")
  user              User              @relation(fields: [userId], references: [id], onDelete: Cascade)
  hscMarks          Float?            @map("hsc_marks")
  cutoff            Float?            @map("cutoff")
  profilePhoto      String?           @map("profile_photo")
  bio               String?
  interests         String?           // Comma-separated or stringified JSON
  skills            String?           // Comma-separated or stringified JSON
  careerGoals       String?           @map("career_goals")
  locationPref      String?           @map("location_pref")
  budgetPref        Float?            @map("budget_pref")
  coursePref        String?           @map("course_pref")

  applications      Application[]
  eventRegistrations EventRegistration[]
  reviews           Review[]
  ratings           Rating[]
  quizResults       QuizResult[]
  aiRecommendations AIRecommendation[]
  savedItems        SavedItem[]

  @@map("students")
}

// ─────────────────────────────────────────
// 3. COLLEGE PROFILE
// ─────────────────────────────────────────
model College {
  userId         Int             @id @map("user_id")
  user           User            @relation(fields: [userId], references: [id], onDelete: Cascade)
  collegeName    String          @map("college_name")
  address        String?         @db.Text
  city           String?
  state          String?
  website        String?         @db.VarChar(500)
  logo           String?         @db.VarChar(500)
  description    String?         @db.Text
  established    Int?
  accreditation  String?
  infrastructure String?         @db.Text
  hostelInfo     String?         @db.Text @map("hostel_info")
  feeStructure   String?         @db.Text @map("fee_structure")

  courses        Course[]
  events         Event[]
  scholarships   Scholarship[]
  placements     PlacementData[]
  applications   Application[]
  reviews        Review[]
  ratings        Rating[]

  @@map("colleges")
}

// ─────────────────────────────────────────
// 4. COURSES
// ─────────────────────────────────────────
model Course {
  id           Int           @id @default(autoincrement())
  collegeId    Int           @map("college_id")
  college      College       @relation(fields: [collegeId], references: [userId], onDelete: Cascade)
  courseName   String        @map("course_name")
  cutoff       Float
  seats        Int?
  duration     String?       // e.g. "4 Years"
  department   String?
  feePerYear   Float?        @map("fee_per_year")
  createdAt    DateTime      @default(now()) @map("created_at")

  applications Application[]

  @@map("courses")
}

// ─────────────────────────────────────────
// 5. EVENTS / SYMPOSIUMS
// ─────────────────────────────────────────
model Event {
  id                  Int                 @id @default(autoincrement())
  collegeId           Int                 @map("college_id")
  college             College             @relation(fields: [collegeId], references: [userId], onDelete: Cascade)
  name                String
  description         String?             @db.Text
  eventDate           DateTime            @map("event_date")
  location            String?
  posterUrl           String?             @db.VarChar(500) @map("poster_url")
  registrationDeadline DateTime?          @map("registration_deadline")
  maxParticipants     Int?                @map("max_participants")
  createdAt           DateTime            @default(now()) @map("created_at")

  registrations       EventRegistration[]
  applications        Application[]

  @@map("events")
}

// ─────────────────────────────────────────
// 6. EVENT REGISTRATION TRACKER
// ─────────────────────────────────────────
model EventRegistration {
  id           Int      @id @default(autoincrement())
  eventId      Int      @map("event_id")
  event        Event    @relation(fields: [eventId], references: [id], onDelete: Cascade)
  studentId    Int      @map("student_id")
  student      Student  @relation(fields: [studentId], references: [userId], onDelete: Cascade)
  registeredAt DateTime @default(now()) @map("registered_at")

  @@unique([eventId, studentId])
  @@map("event_registrations")
}

// ─────────────────────────────────────────
// 7. SCHOLARSHIPS
// ─────────────────────────────────────────
model Scholarship {
  id          Int      @id @default(autoincrement())
  collegeId   Int?     @map("college_id")
  college     College? @relation(fields: [collegeId], references: [userId], onDelete: Cascade)
  type        String   @default("private") // 'government' | 'private' | 'international'
  name        String
  description String?  @db.Text
  amount      Float?
  eligibility String?  @db.Text
  deadline    DateTime?
  createdAt   DateTime @default(now()) @map("created_at")

  @@map("scholarships")
}

// ─────────────────────────────────────────
// 8. INTERNSHIPS
// ─────────────────────────────────────────
model Internship {
  id             Int           @id @default(autoincrement())
  companyName    String        @map("company_name")
  title          String
  description    String?       @db.Text
  stipend        Float?
  duration       String?       // e.g. "3 months"
  location       String?
  eligibility    String?       @db.Text
  skillsRequired String?       @map("skills_required") // Comma-separated values
  deadline       DateTime?
  createdAt      DateTime      @default(now()) @map("created_at")

  applications   Application[]

  @@map("internships")
}

// ─────────────────────────────────────────
// 9. ADMISSIONS & INTERNSHIP APPLICATIONS
// ─────────────────────────────────────────
model Application {
  id           Int         @id @default(autoincrement())
  studentId    Int         @map("student_id")
  student      Student     @relation(fields: [studentId], references: [userId], onDelete: Cascade)
  collegeId    Int         @map("college_id")
  college      College     @relation(fields: [collegeId], references: [userId], onDelete: Cascade)
  courseId     Int?        @map("course_id")
  course       Course?     @relation(fields: [courseId], references: [id], onDelete: SetNull)
  type         String      @default("admission") // 'admission' | 'internship' | 'event'
  eventId      Int?        @map("event_id")
  event        Event?      @relation(fields: [eventId], references: [id], onDelete: SetNull)
  internshipId Int?        @map("internship_id")
  internship   Internship? @relation(fields: [internshipId], references: [id], onDelete: SetNull)
  status       String      @default("pending") // 'pending' | 'accepted' | 'rejected'
  message      String?     @db.Text
  appliedAt    DateTime    @default(now()) @map("applied_at")
  updatedAt    DateTime    @updatedAt @map("updated_at")

  @@map("applications")
}

// ─────────────────────────────────────────
// 10. REVIEWS
// ─────────────────────────────────────────
model Review {
  id        Int      @id @default(autoincrement())
  studentId Int      @map("student_id")
  student   Student  @relation(fields: [studentId], references: [userId], onDelete: Cascade)
  collegeId Int      @map("college_id")
  college   College  @relation(fields: [collegeId], references: [userId], onDelete: Cascade)
  content   String   @db.Text
  rating    Int      @default(5)
  createdAt DateTime @default(now()) @map("created_at")

  @@map("reviews")
}

// ─────────────────────────────────────────
// 11. RATINGS
// ─────────────────────────────────────────
model Rating {
  id        Int     @id @default(autoincrement())
  studentId Int     @map("student_id")
  student   Student @relation(fields: [studentId], references: [userId], onDelete: Cascade)
  collegeId Int     @map("college_id")
  college   College @relation(fields: [collegeId], references: [userId], onDelete: Cascade)
  score     Int

  @@map("ratings")
}

// ─────────────────────────────────────────
// 12. NOTIFICATIONS
// ─────────────────────────────────────────
model Notification {
  id        Int      @id @default(autoincrement())
  userId    Int      @map("user_id")
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  title     String
  message   String   @db.Text
  isRead    Boolean  @default(false) @map("is_read")
  createdAt DateTime @default(now()) @map("created_at")

  @@map("notifications")
}

// ─────────────────────────────────────────
// 13. QUIZ RESULTS
// ─────────────────────────────────────────
model QuizResult {
  id              Int      @id @default(autoincrement())
  studentId       Int      @map("student_id")
  student         Student  @relation(fields: [studentId], references: [userId], onDelete: Cascade)
  careerPath      String   @map("career_path")
  personality     String
  aptitudeScore   Float    @map("aptitude_score")
  interestMapping String?  @db.Text @map("interest_mapping") // stringified JSON
  skillsAnalysis  String?  @db.Text @map("skills_analysis")  // stringified JSON
  recommendations String?  @db.Text
  createdAt       DateTime @default(now()) @map("created_at")

  @@map("quiz_results")
}

// ─────────────────────────────────────────
// 14. PLACEMENT RECORD
// ─────────────────────────────────────────
model PlacementData {
  id               Int      @id @default(autoincrement())
  collegeId        Int      @map("college_id")
  college          College  @relation(fields: [collegeId], references: [userId], onDelete: Cascade)
  year             Int
  highestPackage   Float?   @map("highest_package") // LPA
  averagePackage   Float?   @map("average_package") // LPA
  placementPercent Float?   @map("placement_percent")
  topRecruiters    String?  @db.Text @map("top_recruiters") // comma-separated
  description      String?  @db.Text
  createdAt        DateTime @default(now()) @map("created_at")

  @@map("placements")
}

// ─────────────────────────────────────────
// 15. AI RECOMMENDATIONS
// ─────────────────────────────────────────
model AIRecommendation {
  id           Int      @id @default(autoincrement())
  studentId    Int      @map("student_id")
  student      Student  @relation(fields: [studentId], references: [userId], onDelete: Cascade)
  colleges     String?  @db.Text // stringified JSON
  scholarships String?  @db.Text // stringified JSON
  careers      String?  @db.Text // stringified JSON
  generatedAt  DateTime @default(now()) @map("generated_at")

  @@map("ai_recommendations")
}

// ─────────────────────────────────────────
// 16. SAVED ITEMS
// ─────────────────────────────────────────
model SavedItem {
  id        Int      @id @default(autoincrement())
  studentId Int      @map("student_id")
  student   Student  @relation(fields: [studentId], references: [userId], onDelete: Cascade)
  type      String   // 'college' | 'scholarship' | 'internship' | 'event'
  itemId    Int      @map("item_id")
  createdAt DateTime @default(now()) @map("created_at")

  @@unique([studentId, type, itemId])
  @@map("saved_items")
}

// ─────────────────────────────────────────
// 17. ACTIVITY LOGS
// ─────────────────────────────────────────
model ActivityLog {
  id        Int      @id @default(autoincrement())
  userId    Int      @map("user_id")
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  action    String
  details   String?  @db.Text
  timestamp DateTime @default(now())

  @@map("activity_logs")
}
